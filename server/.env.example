# Copy to server/.env for local development

EXPRESS_PORT=3273

# Firebase Admin (dev) — set to path of a service account key file, or omit to use gcloud ADC
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Firebase client (frontend) — get from Firebase console > Project settings > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=springlakeservices
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
